# Neon PostgreSQL
# Connection string din Neon Dashboard → Project → Connection Details
DATABASE_URL="postgresql://neondb_owner:[PASSWORD]@ep-[ID].eu-central-1.aws.neon.tech/neondb?sslmode=require"
# Pentru prisma migrate (aceeași valoare ca DATABASE_URL pe Neon)
DIRECT_URL="postgresql://neondb_owner:[PASSWORD]@ep-[ID].eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Auth.js
AUTH_SECRET=""        # generează cu: openssl rand -base64 32
AUTH_URL=""           # ex: https://primagym.ro  (sau http://localhost:3000 în dev)

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@primagym.ro"

# Stripe
STRIPE_SECRET_KEY=""              # sk_test_... sau sk_live_... din Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""  # pk_live_... sau pk_test_...
STRIPE_WEBHOOK_SECRET=""          # whsec_... din Stripe Dashboard → Webhooks → endpoint → Signing secret
NEXT_PUBLIC_BASE_URL="https://primagym.ro"  # URL-ul de bază al site-ului (fără slash final)
